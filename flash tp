local function tw(obj, props, dur)
	TweenService:Create(obj, TweenInfo.new(dur or 0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), props):Play()
end

local function FindTool(key)
	local bp = player:FindFirstChild("Backpack")
	local ch = player.Character
	if ch then
		for _, t in pairs(ch:GetChildren()) do
			if t:IsA("Tool") and t.Name:lower():find(key:lower()) then return t end
		end
	end
	if bp then
		for _, t in pairs(bp:GetChildren()) do
			if t:IsA("Tool") and t.Name:lower():find(key:lower()) then return t end
		end
	end
	return nil
end

local flashEnabled   = false
local giantEnabled   = false
local sliderValue    = 0.91
local manualOverride = false
local triggerBump    = false
local activeTriggers = {}
local ppsConn        = nil
local hbConn         = nil
local barFill        = nil

local zeroGravEnabled = false
local zeroGravForce   = nil
local zeroGravConn    = nil

local function getPingBase()
	local ping = 80
	pcall(function() ping = player:GetNetworkPing() * 1000 end)
	if ping <= 30 then return 0.91
	elseif ping <= 70 then return 0.92
	elseif ping <= 120 then return 0.93
	else return 0.94 end
end

local function doGiantPotion()
	local hum = player.Character and player.Character:FindFirstChild("Humanoid")
	if not hum then return end
	local potion = FindTool("giant")
	if not potion then return end
	hum:EquipTool(potion)
	task.wait()
	potion:Activate()
	task.wait()
end

local function flashStart()
	if ppsConn then ppsConn:Disconnect() end
	ppsConn = ProximityPromptService.PromptButtonHoldBegan:Connect(function(prompt)
		if not flashEnabled then return end
		if activeTriggers[prompt] then return end
		activeTriggers[prompt] = true
		local start = os.clock()
		local fired = false
		local conn
		conn = RunService.PreRender:Connect(function()
			if not prompt or not prompt.Parent then
				conn:Disconnect(); activeTriggers[prompt] = nil
				if barFill then tw(barFill, {Size = UDim2.new(0, 0, 1, 0)}, 0.3) end
				return
			end
			local progress = math.clamp((os.clock() - start) / prompt.HoldDuration, 0, 1)
			if barFill then barFill.Size = UDim2.new(progress, 0, 1, 0) end
			if not fired and progress >= sliderValue then
				fired = true; conn:Disconnect(); activeTriggers[prompt] = nil
				triggerBump = not triggerBump
				local ch  = player.Character
				local hum = ch and ch:FindFirstChild("Humanoid")
				if giantEnabled and hum then
					local currentTool = ch:FindFirstChildOfClass("Tool")
					local currentToolName = currentTool and currentTool.Name or nil
					doGiantPotion()
					if currentToolName then
						local reTool = FindTool(currentToolName)
						if reTool and hum then
							hum:EquipTool(reTool)
							task.wait()
						end
					end
				end
				local tool = ch and ch:FindFirstChildOfClass("Tool")
				if tool then tool:Activate() end
				if barFill then
					barFill.Size = UDim2.new(1, 0, 1, 0)
					task.delay(0.2, function()
						tw(barFill, {Size = UDim2.new(0, 0, 1, 0)}, 0.4)
					end)
				end
			end
		end)
		prompt.PromptButtonHoldEnded:Connect(function()
			if not fired then
				conn:Disconnect(); activeTriggers[prompt] = nil
				if barFill then tw(barFill, {Size = UDim2.new(0, 0, 1, 0)}, 0.3) end
			end
		end)
	end)

	if hbConn then hbConn:Disconnect() end
	hbConn = RunService.Heartbeat:Connect(function()
		if not manualOverride then
			local base = getPingBase()
			sliderValue = triggerBump and base + 0.01 or base
		end
	end)
end

local function flashStop()
	if ppsConn then ppsConn:Disconnect(); ppsConn = nil end
	if hbConn  then hbConn:Disconnect();  hbConn  = nil end
	activeTriggers = {}
	if barFill then tw(barFill, {Size = UDim2.new(0, 0, 1, 0)}, 0.3) end
end

local function enableZeroGrav()
	zeroGravEnabled = true
	local ch  = player.Character
	local hrp = ch and ch:FindFirstChild("HumanoidRootPart")
	if not hrp then return end

	if zeroGravForce then zeroGravForce:Destroy(); zeroGravForce = nil end

	local bf = Instance.new("BodyForce")
	bf.Name = "ZeroGravSlowFall"
	bf.Parent = hrp
	zeroGravForce = bf

	if zeroGravConn then zeroGravConn:Disconnect() end
	zeroGravConn = RunService.Heartbeat:Connect(function()
		if not zeroGravEnabled then return end
		local root = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
		if not root or not zeroGravForce or not zeroGravForce.Parent then return end
		local mass = 0
		for _, part in pairs(player.Character:GetDescendants()) do
			if part:IsA("BasePart") then mass = mass + part:GetMass() end
		end
		local counterForce = mass * workspace.Gravity * 0.92
		zeroGravForce.Force = Vector3.new(0, counterForce, 0)
	end)
end

local function disableZeroGrav()
	zeroGravEnabled = false
	if zeroGravConn then zeroGravConn:Disconnect(); zeroGravConn = nil end
	if zeroGravForce then zeroGravForce:Destroy(); zeroGravForce = nil end
end

local function alignCamera()
	local ch   = player.Character
	local head = ch and ch:FindFirstChild("Head")
	if not head then return end
	local cam = workspace.CurrentCamera
	local pos = head.Position
	local lookDir = cam.CFrame.LookVector
	local flatDir = Vector3.new(lookDir.X, 0, lookDir.Z).Unit
	local pitchRad = math.rad(-37)
	local pitched  = CFrame.new(pos, pos + flatDir) * CFrame.Angles(pitchRad, 0, 0)
	cam.CFrame = pitched
end

