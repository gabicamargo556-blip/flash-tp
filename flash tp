local config = {
    enabled = true,
    giantEnabled = false,
    timingPercent = 90,
    toolName = "Flash Teleport",
    giantToolName = "Giant Potion",
    binds = {
        AlignCamera = "F",
        Rejoin = "R",
        SelfKick = "T"
    }
}

local fileName = "KanyeHub_Settings.json"
local activeKeybindToChange = nil
local activeKeybindButton = nil

local function loadSettings()
    if isfile and isfile(fileName) then
        local success, result = pcall(function()
            return HttpService:JSONDecode(readfile(fileName))
        end)
        if success and type(result) == "table" then
            if result.enabled ~= nil then config.enabled = result.enabled end
            if result.giantEnabled ~= nil then config.giantEnabled = result.giantEnabled end
            if result.timingPercent then
                 config.timingPercent = math.clamp(tonumber(result.timingPercent) or 90, 0, 100)
            end
            if result.binds and type(result.binds) == "table" then
                config.binds.Rejoin = result.binds.Rejoin or "R"
                config.binds.SelfKick = result.binds.SelfKick or "T"
                config.binds.AlignCamera = result.binds.AlignCamera or "F"
            end
        end
    end
end

local function saveSettings()
    if writefile then
        pcall(function()
            writefile(fileName, HttpService:JSONEncode({
                enabled = config.enabled,
                giantEnabled = config.giantEnabled,
                timingPercent = config.timingPercent,
                binds = config.binds
            }))
        end)
    end
end

