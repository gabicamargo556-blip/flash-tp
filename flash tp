local function makeToggleButton(parent, yOffset, labelBase, startOn, onToggle)
	local btn = Instance.new("TextButton")
	btn.Size = UDim2.new(1, 0, 0, 34)
	btn.Position = UDim2.new(0, 0, 0, yOffset)
	btn.BackgroundColor3 = startOn and GREEN or GREY
	btn.BorderSizePixel = 0
	btn.Text = ""
	btn.AutoButtonColor = false
	btn.Parent = parent

	local c = Instance.new("UICorner")
	c.CornerRadius = UDim.new(0, 6)
	c.Parent = btn

	local lbl = Instance.new("TextLabel")
	lbl.Size = UDim2.new(1, 0, 1, 0)
	lbl.BackgroundTransparency = 1
	lbl.Text = labelBase .. (startOn and ": ON" or ": OFF")
	lbl.TextColor3 = Color3.fromRGB(240, 240, 240)
	lbl.TextSize = 11
	lbl.Font = Enum.Font.GothamBold
	lbl.FontFace = Font.new(
		"rbxasset://fonts/families/GothamSSm.json",
		Enum.FontWeight.Bold,
		Enum.FontStyle.Normal
	)
	lbl.Parent = btn

	local on = startOn
	btn.MouseButton1Click:Connect(function()
		on = not on
		lbl.Text = labelBase .. (on and ": ON" or ": OFF")
		TweenService:Create(btn, TWEEN_INFO, {
			BackgroundColor3 = on and GREEN or GREY
		}):Play()
		if onToggle then onToggle(on) end
	end)

	return btn, lbl
end

local function makeActionButton(parent, yOffset, labelText, onClick)
	local btn = Instance.new("TextButton")
	btn.Size = UDim2.new(1, 0, 0, 34)
	btn.Position = UDim2.new(0, 0, 0, yOffset)
	btn.BackgroundColor3 = GREY
	btn.BorderSizePixel = 0
	btn.Text = ""
	btn.AutoButtonColor = false
	btn.Parent = parent

	local c = Instance.new("UICorner")
	c.CornerRadius = UDim.new(0, 6)
	c.Parent = btn

	local lbl = Instance.new("TextLabel")
	lbl.Size = UDim2.new(1, 0, 1, 0)
	lbl.BackgroundTransparency = 1
	lbl.Text = labelText
	lbl.TextColor3 = Color3.fromRGB(240, 240, 240)
	lbl.TextSize = 11
	lbl.Font = Enum.Font.GothamBold
	lbl.FontFace = Font.new(
		"rbxasset://fonts/families/GothamSSm.json",
		Enum.FontWeight.Bold,
		Enum.FontStyle.Normal
	)
	lbl.Parent = btn

	btn.MouseButton1Click:Connect(function()
		TweenService:Create(btn, TWEEN_INFO, { BackgroundColor3 = GREEN }):Play()
		task.delay(0.35, function()
			TweenService:Create(btn, TWEEN_INFO, { BackgroundColor3 = GREY }):Play()
		end)
		if onClick then onClick() end
	end)

	return btn, lbl
end

