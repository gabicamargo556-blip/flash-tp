-- ======================== FUNÇÕES DE CARREGAMENTO/SALVAMENTO ========================
local function loadSettings()
    pcall(function()
        if isfile and isfile(savePath) then
            local content = readfile(savePath)
            local decoded = HttpService:JSONDecode(content)
            if decoded.flashStart then sliderValues.FlashStart = math.clamp(decoded.flashStart, 0, 100) end
            if decoded.laggerPower then sliderValues.LaggerPower = math.clamp(decoded.laggerPower, 0, 100) end
            if decoded.speedConfig then sliderValues.SpeedConfig = math.clamp(decoded.speedConfig, 16, 60) end
            if decoded.fovConfig then sliderValues.FovConfig = math.clamp(decoded.fovConfig, 30, 120) end
            if decoded.transparencyAmount then sliderValues.TransparencyAmount = math.clamp(decoded.transparencyAmount, 0, 1) end
            if decoded.transparency ~= nil then toggleStates.Transparency = decoded.transparency end
            if decoded.autoPotion ~= nil then toggleStates.AutoPotion = decoded.autoPotion end
            if decoded.speedBoost ~= nil then toggleStates.SpeedBoost = decoded.speedBoost end
            if decoded.laggerOnSteal ~= nil then toggleStates.LaggerOnSteal = decoded.laggerOnSteal end
            if decoded.fov ~= nil then toggleStates.FOV = decoded.fov end
            if decoded.alignUp then keybinds.AlignUp = Enum.KeyCode[decoded.alignUp] or Enum.KeyCode.V end
            if decoded.alignDown then keybinds.AlignDown = Enum.KeyCode[decoded.alignDown] or Enum.KeyCode.B end
        end
    end)
    if toggleStates.Transparency then
        enableDecorationTransparency()
    end
end

local function saveSettings()
    pcall(function()
        if writefile then
            local data = {
                flashStart = sliderValues.FlashStart,
                laggerPower = sliderValues.LaggerPower,
                speedConfig = sliderValues.SpeedConfig,
                fovConfig = sliderValues.FovConfig,
                transparencyAmount = sliderValues.TransparencyAmount,
                transparency = toggleStates.Transparency,
                autoPotion = toggleStates.AutoPotion,
                speedBoost = toggleStates.SpeedBoost,
                laggerOnSteal = toggleStates.LaggerOnSteal,
                fov = toggleStates.FOV,
                alignUp = keybinds.AlignUp.Name,
                alignDown = keybinds.AlignDown.Name,
            }
            writefile(savePath, HttpService:JSONEncode(data))
        end
    end)
end

-- ======================== FUNÇÕES DE DECORAÇÃO (TRANSPARENCY) ========================
local function getDecorationParts()
    local parts = {}
    local plots = Workspace:FindFirstChild("Plots")
    if not plots then return parts end
    for _, plot in ipairs(plots:GetChildren()) do
        local decorations = plot:FindFirstChild("Decorations")
        if decorations then
            for _, part in ipairs(decorations:GetDescendants()) do
                if part:IsA("BasePart") then
                    table.insert(parts, part)
                end
            end
        end
    end
    return parts
end

local function enableDecorationTransparency()
    local parts = getDecorationParts()
    for _, part in ipairs(parts) do
        if not decorationOriginal[part] then
            decorationOriginal[part] = part.Transparency
        end
        part.Transparency = sliderValues.TransparencyAmount
    end
    decorationEnabled = true
end

local function disableDecorationTransparency()
    for part, orig in pairs(decorationOriginal) do
        if part and part.Parent then
            part.Transparency = orig
        end
    end
    decorationOriginal = {}
    decorationEnabled = false
end

local function startDecorationWatcher()
    if decorationWatcher then decorationWatcher:Disconnect() end
    decorationWatcher = Workspace.DescendantAdded:Connect(function(obj)
        if not decorationEnabled then return end
        if obj:IsA("BasePart") then
            local plots = Workspace:FindFirstChild("Plots")
            if plots and obj:IsDescendantOf(plots) then
                local decorations = obj:FindFirstAncestor("Decorations")
                if decorations then
                    if not decorationOriginal[obj] then
                        decorationOriginal[obj] = obj.Transparency
                    end
                    task.wait(0.05)
                    if obj and obj.Parent then
                        obj.Transparency = sliderValues.TransparencyAmount
                    end
                end
            end
        end
    end)
end

local function setDecorationEnabled(state)
    if state then
        enableDecorationTransparency()
        startDecorationWatcher()
    else
        if decorationWatcher then decorationWatcher:Disconnect() end
        decorationWatcher = nil
        disableDecorationTransparency()
    end
end

-- ======================== FUNÇÕES DE JOGO ========================
local function getCharacter()
    return LocalPlayer.Character
end

local function getHumanoid()
    local char = getCharacter()
    return char and char:FindFirstChildOfClass("Humanoid")
end

local function triggerLagger()
    if not toggleStates.LaggerOnSteal then return end
    task.spawn(function()
        local lagStrength = math.clamp(sliderValues.LaggerPower / 40, 0.3, 3.0)
        settings().Network.IncomingReplicationLag = lagStrength
        task.wait(2)
        settings().Network.IncomingReplicationLag = 0
    end)
end

local function enableSpeedBoost()
    if boostConn then boostConn:Disconnect() end
    boostConn = RunService.Heartbeat:Connect(function()
        local char = LocalPlayer.Character
        if not char then return end
        local hrp = char:FindFirstChild("HumanoidRootPart")
        local hum = char:FindFirstChildOfClass("Humanoid")
        if not hrp or not hum then return end
        local moveDir = hum.MoveDirection
        if moveDir.Magnitude > 0 then
            local flatDir = Vector3.new(moveDir.X, 0, moveDir.Z).Unit
            hrp.Velocity = Vector3.new(flatDir.X * sliderValues.SpeedConfig, hrp.Velocity.Y, flatDir.Z * sliderValues.SpeedConfig)
        end
    end)
end

local function disableSpeedBoost()
    if boostConn then boostConn:Disconnect() boostConn = nil end
end

local function enableFovChanger()
    if fovConn then fovConn:Disconnect() end
    fovConn = RunService.RenderStepped:Connect(function()
        if toggleStates.FOV then
            Camera.FieldOfView = sliderValues.FovConfig
        end
    end)
end

local function disableFovChanger()
    if fovConn then fovConn:Disconnect() fovConn = nil end
    Camera.FieldOfView = 70
end

local function EquipCarpet()
    local char = LocalPlayer.Character
    local backpack = LocalPlayer:FindFirstChild("Backpack")
    local carpet = backpack and backpack:FindFirstChild("Flying Carpet") or (char and char:FindFirstChild("Flying Carpet"))
    if carpet and char then
        local hum = char:FindFirstChildOfClass("Humanoid")
        if hum then hum:EquipTool(carpet) task.wait(0.02) end
    end
end

local function EquipFlash()
    local flashTool = LocalPlayer.Backpack:FindFirstChild("Flash Teleport") or (LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Flash Teleport"))
    if flashTool then
        local hum = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
        if hum then hum:EquipTool(flashTool) end
    end
end

local function ExecuteAlign()
    EquipCarpet()
    local char = LocalPlayer.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    local plots = workspace:FindFirstChild("Plots")
    if root and plots then
        local target = nil
        local dist = math.huge
        for _, plot in ipairs(plots:GetChildren()) do
            if plot.Name == LocalPlayer.Name then continue end
            local podiums = plot:FindFirstChild("AnimalPodiums")
            if podiums then
                for _, pod in ipairs(podiums:GetChildren()) do
                    local base = pod:FindFirstChild("Base")
                    local spawn = base and base:FindFirstChild("Spawn")
                    if spawn then
                        local yDiff = math.abs(spawn.Position.Y - root.Position.Y)
                        if yDiff < 5 then
                            local d = (spawn.Position - root.Position).Magnitude
                            if d < dist then dist = d target = spawn end
                        end
                    end
                end
            end
        end
        if target then
            root.CFrame = target.CFrame + Vector3.new(0, 3, 0)
            task.wait(0.05)
            local _, currentYaw, _ = Camera.CFrame:ToOrientation()
            Camera.CameraType = Enum.CameraType.Scriptable
            Camera.CFrame = CFrame.new(Camera.CFrame.Position) * CFrame.fromOrientation(0.75, currentYaw, 0)
            task.wait(0.05)
            Camera.CameraType = Enum.CameraType.Custom
            root.CFrame = root.CFrame * CFrame.Angles(0, math.pi, 0)
            task.wait(0.12)
            EquipFlash()
        end
    end
end

