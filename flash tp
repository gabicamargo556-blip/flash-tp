do
	local sliderDragging = false
	local SLIDER_MIN = 0.85
	local SLIDER_MAX = 0.99

	local function updateSlider(inputPos)
		local trackAbsPos  = SliderTrack.AbsolutePosition.X
		local trackAbsSize = SliderTrack.AbsoluteSize.X
		local raw = math.clamp((inputPos.X - trackAbsPos) / trackAbsSize, 0, 1)

		local value = SLIDER_MIN + (SLIDER_MAX - SLIDER_MIN) * raw
		value = math.floor(value * 100 + 0.5) / 100

		sliderValue    = value
		manualOverride = true

		local pct = math.floor(value * 100 + 0.5)
		SliderFill.Size   = UDim2.new(raw, 0, 1, 0)
		Knob.Position     = UDim2.new(raw, 0, 0.5, 0)
		TriggerLabel.Text = "TRIGGER: " .. pct .. "%"
	end

	Knob.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1
			or input.UserInputType == Enum.UserInputType.Touch then
			sliderDragging = true
		end
	end)

	Knob.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1
			or input.UserInputType == Enum.UserInputType.Touch then
			sliderDragging = false
		end
	end)

	UserInputService.InputChanged:Connect(function(input)
		if sliderDragging and (input.UserInputType == Enum.UserInputType.MouseMovement
			or input.UserInputType == Enum.UserInputType.Touch) then
			updateSlider(input.Position)
		end
	end)

	SliderTrack.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1
			or input.UserInputType == Enum.UserInputType.Touch then
			updateSlider(input.Position)
			sliderDragging = true
		end
	end)

	SliderTrack.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1
			or input.UserInputType == Enum.UserInputType.Touch then
			sliderDragging = false
		end
	end)
end
