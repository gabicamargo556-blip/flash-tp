local function createSlider(parent, labelText, yPos, stateKey, minVal, maxVal, isPercent, extraAction)
    local container = Instance.new("Frame")
    container.Size = UDim2.new(0.85, 0, 0, 28)
    container.Position = UDim2.new(0.075, 0, 0, yPos)
    container.BackgroundTransparency = 1
    container.Parent = parent

    local lbl = Instance.new("TextLabel")
    lbl.Size = UDim2.new(1, 0, 0, 9)
    lbl.Position = UDim2.new(0, 0, 0, 0)
    lbl.BackgroundTransparency = 1
    lbl.Text = labelText
    lbl.TextColor3 = COLOR_TEXT_DIM
    lbl.Font = Enum.Font.GothamBold
    lbl.TextSize = 7
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.Parent = container

    local valLbl = Instance.new("TextLabel")
    valLbl.Size = UDim2.new(1, 0, 0, 9)
    valLbl.Position = UDim2.new(0, 0, 0, 9)
    valLbl.BackgroundTransparency = 1
    valLbl.TextColor3 = COLOR_TEXT
    valLbl.Font = Enum.Font.Gotham
    valLbl.TextSize = 7
    valLbl.TextXAlignment = Enum.TextXAlignment.Right
    valLbl.Parent = container

    local function fmtVal(v)
        if isPercent then
            return string.format("%.1f%%", v)
        else
            return tostring(math.floor(v))
        end
    end
    valLbl.Text = fmtVal(sliderValues[stateKey])

    local track = Instance.new("Frame")
    track.Size = UDim2.new(1, 0, 0, 4)
    track.Position = UDim2.new(0, 0, 0, 20)
    track.BackgroundColor3 = COLOR_SLIDER_BG
    track.BorderSizePixel = 0
    track.Parent = container

    local track_Corner = Instance.new("UICorner")
    track_Corner.CornerRadius = UDim.new(1, 0)
    track_Corner.Parent = track

    local fill = Instance.new("Frame")
    local initPct = (sliderValues[stateKey] - minVal) / (maxVal - minVal)
    fill.Size = UDim2.new(initPct, 0, 1, 0)
    fill.BackgroundColor3 = COLOR_BLUE
    fill.BorderSizePixel = 0
    fill.Parent = track

    local fill_Corner = Instance.new("UICorner")
    fill_Corner.CornerRadius = UDim.new(1, 0)
    fill_Corner.Parent = fill

    local thumb = Instance.new("Frame")
    thumb.Size = UDim2.new(0, 8, 0, 8)
    thumb.Position = UDim2.new(initPct, -4, 0.5, -4)
    thumb.BackgroundColor3 = COLOR_WHITE
    thumb.BorderSizePixel = 0
    thumb.Parent = track

    local thumb_Corner = Instance.new("UICorner")
    thumb_Corner.CornerRadius = UDim.new(1, 0)
    thumb_Corner.Parent = thumb

    local dragging = false

    -- Função para atualizar o slider
    local function updateSlider(val)
        val = math.clamp(val, minVal, maxVal)
        sliderValues[stateKey] = val
        local pct = (val - minVal) / (maxVal - minVal)
        fill.Size = UDim2.new(pct, 0, 1, 0)
        thumb.Position = UDim2.new(pct, -4, 0.5, -4)
        valLbl.Text = fmtVal(val)
        saveSettings()
        
        if stateKey == "SpeedConfig" and toggleStates.SpeedBoost then
            enableSpeedBoost()
        elseif stateKey == "TransparencyAmount" and toggleStates.Transparency then
            setDecorationEnabled(false)
            task.wait(0.1)
            setDecorationEnabled(true)
        end
        if extraAction then extraAction(val) end
    end

    -- Drag do slider
    thumb.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or
           input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
        end
    end)

    -- Input manual (clicar no número)
    valLbl.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            local box = Instance.new("TextBox")
            box.Size = UDim2.new(0.5, 0, 1, 0)
            box.Position = UDim2.new(0.5, 0, 0, 0)
            box.BackgroundTransparency = 1
            box.TextColor3 = COLOR_BLUE
            box.Font = Enum.Font.Gotham
            box.TextSize = 7
            box.TextXAlignment = Enum.TextXAlignment.Right
            box.Text = tostring(sliderValues[stateKey])
            box.Parent = container
            
            box:CaptureFocus()
            
            box.FocusLost:Connect(function(enterPressed)
                if enterPressed then
                    local val = tonumber(box.Text)
                    if val then
                        updateSlider(val)
                    end
                end
                box:Destroy()
            end)
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if not dragging then return end
        if input.UserInputType == Enum.UserInputType.MouseMovement or
           input.UserInputType == Enum.UserInputType.Touch then
            local trackPos = track.AbsolutePosition.X
            local trackSize = track.AbsoluteSize.X
            local mouseX = input.Position.X
            local pct = math.clamp((mouseX - trackPos) / trackSize, 0, 1)
            local val = minVal + pct * (maxVal - minVal)
            updateSlider(val)
        end
    end)

    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or
           input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)

    return container
end

