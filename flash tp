UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if activeKeybindToChange then
        if input.UserInputType == Enum.UserInputType.Keyboard then
            local allowedKey = input.KeyCode
            if allowedKey ~= Enum.KeyCode.Unknown and allowedKey ~= Enum.KeyCode.Escape then
                config.binds[activeKeybindToChange] = allowedKey.Name
                if activeKeybindButton then
                     activeKeybindButton.Text = "[" .. allowedKey.Name .. "]"
                end
                saveSettings()
            else
                if activeKeybindButton then
                    activeKeybindButton.Text = "[" .. config.binds[activeKeybindToChange] .. "]"
                end
            end
            activeKeybindToChange = nil
            activeKeybindButton = nil
        end
        return
    end

    if gameProcessed then return end
    if UserInputService:GetFocusedTextBox() then return end

    if input.UserInputType == Enum.UserInputType.Keyboard then
        local success1, key1 = pcall(function() return Enum.KeyCode[config.binds.Rejoin] end)
        local success2, key2 = pcall(function() return Enum.KeyCode[config.binds.SelfKick] end)
        local success3, key3 = pcall(function() return Enum.KeyCode[config.binds.AlignCamera] end)

        if success1 and input.KeyCode == key1 then
            triggerRejoin()
        elseif success2 and input.KeyCode == key2 then
            triggerSelfKick()
        elseif success3 and input.KeyCode == key3 then
            triggerAlignCamera()
        end
    end
end)

